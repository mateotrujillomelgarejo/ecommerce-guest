{
  "analysis": {
    "analyzer": {
      "spanish": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "spanish_stop", "spanish_stemmer", "asciifolding"]
      }
    },
    "filter": {
      "spanish_stop": {
        "type": "stop",
        "stopwords": "_spanish_"
      },
      "spanish_stemmer": {
        "type": "stemmer",
        "language": "spanish"
      }
    }
  }
}